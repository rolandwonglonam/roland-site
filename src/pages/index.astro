---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry } from 'astro:content';

const page = await getEntry('pages', 'home');
const d = page!.data;
---

<BaseLayout title="首页" description="Roland Wayne — 卫生经济学博士候选人，独立写作者，AI 系统实践者。用跨学科思维拆解复杂问题。">
  <section class="min-h-[90vh] flex items-center">
    <div class="max-w-6xl mx-auto px-6 py-20">
      <div class="grid md:grid-cols-2 gap-16 items-center">
        <div>
          <p class="text-accent uppercase tracking-[0.3em] text-sm mb-4">{d.tagline}</p>
          <h1 class="font-serif text-4xl md:text-6xl leading-tight mb-6">
            {d.title_line1}<br />
            <span class="text-accent">{d.title_accent}</span><br />
            {d.title_line2}
          </h1>
          <p class="text-text-secondary text-lg leading-relaxed mb-8 max-w-lg">{d.description}</p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="/services" class="px-6 py-3 bg-accent text-primary font-medium text-sm uppercase tracking-wider hover:bg-accent-hover transition-colors text-center">
              {d.cta_primary}
            </a>
            <a href="/research" class="px-6 py-3 border border-border text-text-secondary text-sm uppercase tracking-wider hover:border-accent hover:text-accent transition-colors text-center">
              {d.cta_secondary}
            </a>
          </div>
        </div>
        <div class="hidden md:block">
          <div class="aspect-[3/4] overflow-hidden border border-border">
            <img src="/profile.jpg" alt="Roland Wayne" class="w-full h-full object-cover object-top" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-secondary py-20">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid md:grid-cols-3 gap-8">
        {d.pillars.map((p: any) => (
          <div class="p-8 border border-border hover:border-accent/30 transition-colors">
            <div class="text-accent text-3xl font-serif mb-4">{p.number}</div>
            <h3 class="text-lg font-medium mb-3">{p.title}</h3>
            <p class="text-text-secondary text-sm leading-relaxed">{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="font-serif text-3xl mb-6">{d.cta_title}</h2>
      <p class="text-text-secondary mb-8 text-lg">{d.cta_desc}</p>
      <a href="/contact" class="inline-block px-8 py-4 bg-accent text-primary font-medium text-sm uppercase tracking-wider hover:bg-accent-hover transition-colors">
        {d.cta_button}
      </a>
    </div>
  </section>
</BaseLayout>
