---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry } from 'astro:content';

const page = await getEntry('pages', 'services');
const d = page!.data;
---

<BaseLayout title="服务" description="Wayne Insight Spring — 为家庭提供国际医学教育的高端咨询服务。">
  <section class="py-20">
    <div class="max-w-4xl mx-auto px-6">
      <p class="text-accent uppercase tracking-[0.3em] text-sm mb-4">{d.subtitle}</p>
      <h1 class="font-serif text-4xl md:text-5xl mb-6">{d.title}</h1>
      <p class="text-text-secondary text-lg mb-16 max-w-2xl">{d.description}</p>

      <div class="bg-secondary p-8 border border-border mb-16">
        <p class="text-accent font-serif text-lg mb-4">{d.philosophy}</p>
        <p class="text-text-secondary leading-relaxed">{d.philosophy_desc}</p>
      </div>

      <div class="space-y-8 mb-16">
        {d.services.map((svc: any) => (
          <div class="p-8 border border-border hover:border-accent/30 transition-colors">
            <div class="flex flex-col md:flex-row md:items-center md:justify-between mb-4">
              <h3 class="text-xl font-medium">{svc.title}</h3>
              <span class="text-accent font-serif text-lg">{svc.tier}</span>
            </div>
            <p class="text-text-secondary text-sm leading-relaxed mb-4">{svc.desc}</p>
            <div class="flex flex-wrap gap-2">
              {svc.tags.map((tag: string) => (
                <span class="text-xs text-text-muted border border-border px-2 py-1">{tag}</span>
              ))}
            </div>
          </div>
        ))}
      </div>

      <div class="text-center py-12">
        <p class="text-text-secondary mb-6">{d.cta_intro}</p>
        <a href="/contact" class="inline-block px-8 py-4 bg-accent text-primary font-medium text-sm uppercase tracking-wider hover:bg-accent-hover transition-colors">
          {d.cta_button}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
