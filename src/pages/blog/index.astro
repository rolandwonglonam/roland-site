---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Blog" description="Insights on health science, education consulting, AI research thinking, and decision-making frameworks.">
  <section class="py-20">
    <div class="max-w-4xl mx-auto px-6">
      <p class="text-accent uppercase tracking-[0.3em] text-sm mb-4">Blog</p>
      <h1 class="font-serif text-4xl md:text-5xl mb-12">Thoughts & Insights</h1>

      {posts.length === 0 ? (
        <p class="text-text-secondary text-lg">Coming soon — stay tuned for new articles.</p>
      ) : (
        <div class="space-y-8">
          {posts.map(post => (
            <a href={`/blog/${post.id}`} class="block group p-6 border border-border hover:border-accent/30 transition-colors">
              <time class="text-accent text-xs uppercase tracking-wider">
                {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
              </time>
              <h2 class="font-serif text-2xl mt-2 mb-3 group-hover:text-accent transition-colors">
                {post.data.title}
              </h2>
              <p class="text-text-secondary text-sm">{post.data.description}</p>
              {post.data.tags.length > 0 && (
                <div class="flex gap-2 mt-4">
                  {post.data.tags.map(tag => (
                    <span class="text-xs text-text-muted border border-border px-2 py-1">{tag}</span>
                  ))}
                </div>
              )}
            </a>
          ))}
        </div>
      )}
    </div>
  </section>
</BaseLayout>
