---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry } from 'astro:content';

const page = await getEntry('pages', 'university');
const d = page!.data;
---

<BaseLayout title="高校合作" description="国际医学教育合作伙伴 - Roland Wayne">
  <!-- Hero Section -->
  <section class="pt-32 pb-20 bg-gradient-to-b from-secondary to-primary">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <p class="text-accent uppercase tracking-[0.3em] text-sm mb-4">{d.hero_subtitle}</p>
      <h1 class="font-serif text-4xl md:text-5xl mb-6">{d.hero_title}</h1>
    </div>
  </section>

  <!-- Introduction Section -->
  <section class="py-20">
    <div class="max-w-4xl mx-auto px-6">
      <div class="grid md:grid-cols-3 gap-12 items-start">
        <div class="md:col-span-1">
          <img
            src="/profile.jpg"
            alt="Roland Wayne"
            class="w-full aspect-[3/4] object-cover rounded-lg shadow-lg"
          />
        </div>
        <div class="md:col-span-2">
          <h2 class="font-serif text-2xl mb-6">{d.intro_title}</h2>
          <p class="text-text-secondary leading-relaxed mb-8">{d.intro_desc}</p>

          <div class="space-y-3">
            {d.credentials.map((cred: string) => (
              <div class="flex items-start gap-3">
                <span class="text-accent mt-1">▸</span>
                <span class="text-text-secondary">{cred}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Achievements Section -->
  <section class="py-20 bg-secondary">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="font-serif text-2xl text-center mb-12">核心成就</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        {d.achievements.map((item: any) => (
          <div class="text-center">
            <div class="font-serif text-4xl md:text-5xl text-accent mb-2">{item.value}</div>
            <div class="font-medium mb-1">{item.title}</div>
            <div class="text-text-muted text-sm">{item.desc}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Responsibilities Section -->
  <section class="py-20">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="font-serif text-2xl text-center mb-12">工作职责</h2>
      <div class="grid md:grid-cols-3 gap-6">
        {d.responsibilities.map((item: any) => (
          <div class="p-6 border border-border">
            <h3 class="font-medium mb-2">{item.title}</h3>
            <p class="text-text-secondary text-sm">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Expertise Section -->
  <section class="py-20 bg-secondary">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="font-serif text-2xl text-center mb-8">专业领域</h2>
      <div class="flex flex-wrap justify-center gap-3">
        {d.expertise.map((exp: string) => (
          <span class="px-4 py-2 border border-accent/30 text-accent">{exp}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20">
    <div class="max-w-2xl mx-auto px-6 text-center">
      <h2 class="font-serif text-2xl mb-4">{d.cta_title}</h2>
      <p class="text-text-secondary mb-8">{d.cta_desc}</p>
      <a href="/contact" class="inline-block px-8 py-4 bg-accent text-primary font-medium text-sm uppercase tracking-wider hover:bg-accent-hover transition-colors">
        {d.cta_button}
      </a>
    </div>
  </section>
</BaseLayout>
