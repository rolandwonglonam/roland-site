---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry } from 'astro:content';

const page = await getEntry('pages', 'research');
const d = page!.data;
---

<BaseLayout title="研究" description="Roland Wayne 在健康实施科学、低钠盐替代品与心血管疾病预防领域的学术研究。">
  <section class="py-20">
    <div class="max-w-4xl mx-auto px-6">
      <p class="text-accent uppercase tracking-[0.3em] text-sm mb-4">{d.subtitle}</p>
      <h1 class="font-serif text-4xl md:text-5xl mb-6">{d.title}</h1>
      <p class="text-text-secondary text-lg mb-16 max-w-2xl">{d.description}</p>

      <div class="mb-16">
        <h2 class="font-serif text-2xl mb-8 text-accent">{d.current_title}</h2>
        <div class="p-8 border border-border">
          <h3 class="text-xl font-medium mb-3">{d.current.title}</h3>
          <p class="text-text-secondary text-sm leading-relaxed mb-4">{d.current.desc}</p>
          <div class="flex flex-wrap gap-2">
            {d.current.tags.map((tag: string) => (
              <span class="text-xs text-accent border border-accent/30 px-2 py-1">{tag}</span>
            ))}
          </div>
        </div>
      </div>

      <div class="mb-16">
        <h2 class="font-serif text-2xl mb-8 text-accent">{d.publications_title}</h2>
        <div class="space-y-6">
          {d.publications.map((pub: any) => (
            <div class="p-6 border border-border hover:border-accent/30 transition-colors">
              <p class="text-xs text-text-muted uppercase tracking-wider mb-2">{pub.status}</p>
              <h3 class="text-lg font-medium mb-2">{pub.title}</h3>
              <p class="text-text-secondary text-sm">{pub.desc}</p>
            </div>
          ))}
        </div>
      </div>

      <div>
        <h2 class="font-serif text-2xl mb-8 text-accent">{d.interests_title}</h2>
        <div class="grid md:grid-cols-2 gap-4">
          {d.interests.map((item: string) => (
            <div class="p-4 border border-border text-text-secondary text-sm">{item}</div>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
