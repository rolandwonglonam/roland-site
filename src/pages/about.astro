---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry } from 'astro:content';

const page = await getEntry('pages', 'about');
const d = page!.data;
---

<BaseLayout title="关于" description="了解 Roland Wayne 从康复治疗到健康经济学、实施科学与教育咨询的旅程。">
  <section class="py-20">
    <div class="max-w-4xl mx-auto px-6">
      <p class="text-accent uppercase tracking-[0.3em] text-sm mb-4">{d.subtitle}</p>
      <h1 class="font-serif text-4xl md:text-5xl mb-12">{d.title}</h1>

      <div class="space-y-8 text-text-secondary text-lg leading-relaxed">
        {d.paragraphs.map((para: string) => (
          <p>{para}</p>
        ))}
      </div>

      <div class="mt-20">
        <h2 class="font-serif text-2xl mb-8">{d.milestones_title}</h2>
        <div class="space-y-6">
          {d.milestones.map((m: any) => (
            <div class="flex gap-6 items-start">
              <div class="text-accent font-serif text-lg w-20 shrink-0">{m.year}</div>
              <div>
                <p class="text-text-primary font-medium">{m.title}</p>
                <p class="text-text-secondary text-sm mt-1">{m.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
