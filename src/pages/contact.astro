---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry } from 'astro:content';

const page = await getEntry('pages', 'contact');
const d = page!.data;
---

<BaseLayout title="联系" description="联系 Roland Wayne，探讨研究合作或教育咨询事宜。">
  <section class="py-20">
    <div class="max-w-4xl mx-auto px-6">
      <p class="text-accent uppercase tracking-[0.3em] text-sm mb-4">{d.subtitle}</p>
      <h1 class="font-serif text-4xl md:text-5xl mb-6">{d.title}</h1>
      <p class="text-text-secondary text-lg mb-16 max-w-2xl">{d.description}</p>

      <div class="grid md:grid-cols-2 gap-16">
        <div class="space-y-8">
          <div>
            <h3 class="text-sm uppercase tracking-wider text-text-muted mb-2">{d.email_label}</h3>
            <a href={`mailto:${d.email}`} class="text-accent hover:text-accent-hover transition-colors">{d.email}</a>
          </div>
          <div>
            <h3 class="text-sm uppercase tracking-wider text-text-muted mb-2">{d.location_label}</h3>
            <p class="text-text-secondary">{d.location}</p>
          </div>
          <div>
            <h3 class="text-sm uppercase tracking-wider text-text-muted mb-2">{d.affiliation_label}</h3>
            <p class="text-text-secondary">{d.affiliation}</p>
          </div>
          <div>
            <h3 class="text-sm uppercase tracking-wider text-text-muted mb-2">{d.company_label}</h3>
            <p class="text-text-secondary">{d.company}</p>
          </div>
        </div>

        <div>
          <p class="text-text-muted text-sm mb-4">{d.form_note}</p>
          <a href={`mailto:${d.email}`} class="inline-block px-6 py-3 bg-accent text-primary font-medium text-sm uppercase tracking-wider hover:bg-accent-hover transition-colors">
            {d.send_button}
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
